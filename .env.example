# =====================================================================
# CLAI 2026 — Template de configuração
# Copie para `.env` e preencha. NUNCA versione o `.env` real (segredos).
#   PowerShell:  Copy-Item .env.example .env
#   bash:        cp .env.example .env
# =====================================================================

# --- Ambiente ---
APP_ENV=dev

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Origens permitidas para CORS (frontend Vite). Separar por virgula se mais de uma.
CORS_ORIGINS=http://localhost:5173

# --- GCP (projeto compartilhado do time) ---
# Projeto GCP do time. Mesmo valor para todos.
GCP_PROJECT_ID=clai-2026-500018
GCP_REGION=southamerica-east1

# --- BigQuery (acervo analítico) ---
GCP_DATASET=clai

# --- Cloud Storage (arquivos) ---
GCS_BUCKET=clai-dev

# --- Firestore (dados operacionais) ---
# Usa o projeto/região acima; database padrão "(default)".
FIRESTORE_DATABASE=(default)

# --- Gemini ---
# Escolha UM caminho e documente para o time:
#   USE_VERTEX=false -> API do Gemini (google-genai) usando GEMINI_API_KEY
#   USE_VERTEX=true  -> Vertex AI (mesmo SDK, autentica via ADC, sem API key)
USE_VERTEX=false
GEMINI_API_KEY=
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_LITE=gemini-2.5-flash-lite

# --- Vertex AI Vector Search (busca de acervo) ---
# Preenchidos após criar o índice/endpoint. Usados pelo scripts/vector_search.py
VERTEX_INDEX_ID=
VERTEX_INDEX_ENDPOINT_ID=
VERTEX_DEPLOYED_INDEX_ID=clai_index

# --- Isolamento de dados de dev (cada pessoa com o SEU valor) ---
# Prefixa recursos para vários devs não colidirem no mesmo projeto GCP.
DEV_NAMESPACE=
